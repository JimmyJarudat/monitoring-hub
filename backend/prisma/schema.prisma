generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id             String         @id @default(cuid())
  username       String         @unique
  email          String         @unique
  password       String
  roleId         String
  role           Role           @relation(fields: [roleId], references: [id])
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  auditLogs      AuditLog[]
  loginHistory   LoginHistory[]
  refreshTokens  RefreshToken[]
  domainScans    DomainScanHistory[]
  notifications  AppNotificationRecipient[]
  apiTokens      ApiToken[]

  @@map("users")
}

model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([token])
  @@map("refresh_tokens")
}

model Role {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  createdAt   DateTime @default(now())
  users       User[]

  @@map("roles")
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  action    String
  entity    String
  entityId  String?
  oldValue  Json?
  newValue  Json?
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([entity, entityId])
  @@index([createdAt])
  @@map("audit_logs")
}

model AppNotification {
  id         String                       @id @default(cuid())
  type       AppNotificationType
  severity   AppNotificationSeverity
  title      String
  message    String?
  href       String?
  entity     String?
  entityId   String?
  metadata   Json?
  createdAt  DateTime                     @default(now())
  recipients AppNotificationRecipient[]

  @@index([type, createdAt])
  @@index([severity, createdAt])
  @@index([entity, entityId])
  @@index([createdAt])
  @@map("app_notifications")
}

model AppNotificationRecipient {
  id             String          @id @default(cuid())
  notificationId String
  notification   AppNotification @relation(fields: [notificationId], references: [id], onDelete: Cascade)
  userId         String
  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  readAt         DateTime?
  dismissedAt    DateTime?
  createdAt      DateTime        @default(now())

  @@unique([notificationId, userId])
  @@index([userId, readAt, createdAt])
  @@index([userId, dismissedAt, createdAt])
  @@map("app_notification_recipients")
}

enum AppNotificationType {
  INCIDENT
  RESOLVED
  ALERT
  SYSTEM
  DELIVERY
  SECURITY
  REPORT
  MONITOR
}

enum AppNotificationSeverity {
  INFO
  WARNING
  CRITICAL
  SUCCESS
}

model LoginHistory {
  id        String      @id @default(cuid())
  userId    String
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  status    LoginStatus
  ipAddress String?
  userAgent String?
  createdAt DateTime    @default(now())

  @@index([userId])
  @@index([createdAt])
  @@map("login_history")
}

enum LoginStatus {
  SUCCESS
  FAILED
}

// ─── Monitoring ───────────────────────────────────────────────

model Monitor {
  id          String        @id @default(cuid())
  name        String
  type        MonitorType
  config      Json          // host/url/port/credentials ฯลฯ
  credentialId String?
  credential  Credential?   @relation(fields: [credentialId], references: [id], onDelete: SetNull)
  interval    Int           @default(60) // วินาที
  enabled     Boolean       @default(true)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  results     MonitorResult[]
  deviceMetrics DeviceMetricSample[]
  groups      MonitorGroupMember[]
  alertRules  AlertRule[]
  incidents   Incident[]

  @@index([credentialId])
  @@index([type, enabled])
  @@map("monitors")
}

enum MonitorType {
  PING
  TCP
  HTTP
  TLS_CERT
  DNS
  SNMP
  SYSTEM
  DOCKER
  DATABASE
}

model MonitorResult {
  id             String        @id @default(cuid())
  monitorId      String
  monitor        Monitor       @relation(fields: [monitorId], references: [id], onDelete: Cascade)
  status         MonitorStatus
  responseTimeMs Int?
  message        String?
  metadata       Json?         // raw metrics เพิ่มเติม
  checkedAt      DateTime      @default(now())

  @@index([monitorId, checkedAt])
  @@index([checkedAt])
  @@map("monitor_results")
}

enum MonitorStatus {
  UP
  DOWN
  DEGRADED
}

model DeviceMetricSample {
  id          String            @id @default(cuid())
  monitorId   String
  monitor     Monitor           @relation(fields: [monitorId], references: [id], onDelete: Cascade)
  metricGroup DeviceMetricGroup
  metricKey   String
  instance    String?
  value       Float
  unit        String
  collectedAt DateTime          @default(now())

  @@index([monitorId, collectedAt])
  @@index([monitorId, metricGroup, collectedAt])
  @@index([monitorId, metricKey, instance, collectedAt])
  @@map("device_metric_samples")
}

enum DeviceMetricGroup {
  SYSTEM
  DISK
  NET
}

model MonitorGroup {
  id          String             @id @default(cuid())
  name        String             @unique
  description String?
  color       String?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  monitors    MonitorGroupMember[]

  @@map("monitor_groups")
}

model MonitorGroupMember {
  groupId    String
  monitorId  String
  group      MonitorGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  monitor    Monitor      @relation(fields: [monitorId], references: [id], onDelete: Cascade)
  createdAt  DateTime     @default(now())

  @@id([groupId, monitorId])
  @@index([monitorId])
  @@map("monitor_group_members")
}

model Credential {
  id          String         @id @default(cuid())
  name        String
  type        CredentialType
  username    String?
  secret      String
  notes       String?
  metadata    Json?
  monitors    Monitor[]
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@index([type, createdAt])
  @@map("credentials")
}

enum CredentialType {
  SNMP_COMMUNITY
  USERNAME_PASSWORD
  API_TOKEN
  SSH_KEY
}

model AlertRule {
  id          String             @id @default(cuid())
  monitorId   String
  monitor     Monitor            @relation(fields: [monitorId], references: [id], onDelete: Cascade)
  metric      String             // "status" | "response_time"
  operator    AlertOperator
  threshold   Float
  severity    AlertSeverity
  enabled     Boolean            @default(true)
  createdAt   DateTime           @default(now())
  channels    AlertRuleChannel[]
  incidents   Incident[]

  @@map("alert_rules")
}

enum AlertOperator {
  GT
  LT
  EQ
  NEQ
}

enum AlertSeverity {
  INFO
  WARNING
  CRITICAL
}

model NotificationChannel {
  id        String             @id @default(cuid())
  name      String
  type      ChannelType
  config    Json               // token/webhookUrl/smtp — เข้ารหัสก่อนเก็บ
  enabled   Boolean            @default(true)
  createdAt DateTime           @default(now())
  rules     AlertRuleChannel[]

  @@map("notification_channels")
}

enum ChannelType {
  LINE
  EMAIL
  SLACK
  DISCORD
  TELEGRAM
  WEBHOOK
}

model AlertRuleChannel {
  alertRuleId String
  channelId   String
  alertRule   AlertRule           @relation(fields: [alertRuleId], references: [id], onDelete: Cascade)
  channel     NotificationChannel @relation(fields: [channelId], references: [id], onDelete: Cascade)

  @@id([alertRuleId, channelId])
  @@map("alert_rule_channels")
}

model Incident {
  id          String         @id @default(cuid())
  monitorId   String
  monitor     Monitor        @relation(fields: [monitorId], references: [id], onDelete: Cascade)
  alertRuleId String?
  alertRule   AlertRule?     @relation(fields: [alertRuleId], references: [id], onDelete: SetNull)
  status      IncidentStatus @default(OPEN)
  message     String?
  startedAt   DateTime       @default(now())
  resolvedAt  DateTime?

  @@index([monitorId, status])
  @@index([status, startedAt])
  @@map("incidents")
}

enum IncidentStatus {
  OPEN
  RESOLVED
}

model SystemSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt

  @@map("system_settings")
}

enum LogLevel {
  INFO
  WARN
  ERROR
}

model SystemLog {
  id        String   @id @default(cuid())
  level     LogLevel
  category  String
  message   String
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([level, createdAt])
  @@index([category, createdAt])
  @@index([createdAt])
  @@map("system_logs")
}

model DomainScanHistory {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  domain          String
  registrar       String?
  dnsProvider     String
  nameserverCount Int
  subdomainCount  Int
  onlineCount     Int
  durationMs      Int
  scannerIp       String?
  scannedAt       DateTime @default(now())

  @@index([userId])
  @@index([domain])
  @@index([scannedAt])
  @@map("domain_scan_history")
}

model ApiToken {
  id         String    @id @default(cuid())
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  name       String
  tokenHash  String    @unique
  prefix     String    // "mh_" + first 8 hex chars — แสดงแทน token จริง
  expiresAt  DateTime?
  lastUsedAt DateTime?
  createdAt  DateTime  @default(now())

  @@index([userId])
  @@index([tokenHash])
  @@map("api_tokens")
}
