# ===== Server =====
PORT=3000
HOST=0.0.0.0
NODE_ENV=production

# ===== Database =====
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DB_NAME?schema=public"

# ===== JWT =====
# สร้างด้วย: openssl rand -hex 64
JWT_SECRET=

# ===== CORS =====
# หลาย origin คั่นด้วย comma
CORS_ORIGINS=https://yourdomain.com
